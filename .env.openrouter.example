# Default model used when an Agent, Crew, planner, or HITL helper does not set llm explicitly.
MODEL=openrouter/deepseek/deepseek-chat

# Native OpenRouter provider credential used by CrewAI's OpenAI-compatible provider.
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional: force the OpenAI-compatible env style instead of MODEL.
# OPENAI_MODEL_NAME=openrouter/deepseek/deepseek-chat
# OPENAI_API_BASE=https://openrouter.ai/api/v1
# OPENAI_API_KEY=your_openrouter_api_key

# Optional: if you enable memory/embeddings, configure an embedder separately.
# EMBEDDINGS_OPENAI_MODEL_NAME=text-embedding-3-small
# EMBEDDINGS_OPENAI_API_KEY=your_embedding_provider_key
# EMBEDDINGS_OPENAI_API_BASE=https://api.openai.com/v1
